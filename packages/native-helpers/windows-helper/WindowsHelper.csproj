<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <!-- Compressed bundles are inflated into private memory on every launch
         (~3-4x slower start, ~70 MB extra resident RAM for the process lifetime);
         the Squirrel package already compresses the download. -->
    <EnableCompressionInSingleFile>false</EnableCompressionInSingleFile>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <AssemblyName>WindowsHelper</AssemblyName>
    <RootNamespace>WindowsHelper</RootNamespace>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="9.0.7" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="Interop.UIAutomationClient" Version="10.19041.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows' Or '$(RuntimeIdentifier)' == 'win-x64'">
    <FrameworkReference Include="Microsoft.WindowsDesktop.App" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\rec-start.mp3" />
    <EmbeddedResource Include="Resources\rec-stop.mp3" />
    <EmbeddedResource Include="Resources\error-chime.mp3" />
  </ItemGroup>

  <!-- Self-contained publish ships the full Microsoft.WindowsDesktop.App runtime pack
       regardless of FrameworkReference profile (SDK limitation), so WPF (~44 MB managed
       + ~8 MB native, all unused) must be dropped by pruning the publish list. Hooks
       ComputeResolvedFilesToPublishList because the single-file bundler snapshots its
       inputs before ComputeFilesToPublish. -->
  <Target Name="StripWpfFromPublish" AfterTargets="ComputeResolvedFilesToPublishList">
    <ItemGroup>
      <_WpfPublishFile Include="@(ResolvedFileToPublish)"
        Condition="$([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('Presentation')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('wpfgfx')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('D3DCompiler')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('PenImc')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('ReachFramework')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('System.Xaml')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('UIAutomation')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('WindowsBase')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('System.Windows.Controls.Ribbon')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('System.Windows.Input.Manipulations')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('System.Windows.Presentation')) Or
                   $([System.String]::Copy('%(ResolvedFileToPublish.Filename)').StartsWith('System.Printing'))" />
      <ResolvedFileToPublish Remove="@(_WpfPublishFile)" />
    </ItemGroup>
  </Target>

</Project>
